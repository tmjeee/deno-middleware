{
  "name": "@tmjeee/deno-middleware",
  "version": "0.2.0",
  "exports": {
    ".": "./mod.ts",
    "./v2": "./mod_v2.ts"
  },
  "publish": {
    "exclude": [
      ".git",
      ".github",
      ".vscode",
      "tests",
      "examples",
      "*.test.ts",
      "*.config.ts"
    ]
  },
  "tasks": {
    "test": "deno test --allow-all",
    "test:watch": "deno test --allow-all --watch",
    "check": "deno check mod.ts mod_v2.ts",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check",
    "lint": "deno lint",
    "coverage": "deno test --allow-all --coverage=coverage && deno coverage coverage --lcov --output=coverage.lcov"
  },
  "fmt": {
    "useTabs": false,
    "lineWidth": 100,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": false,
    "proseWrap": "preserve"
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  },
  "test": {
    "include": ["**/*_test.ts", "**/*.test.ts"]
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.0",
    "@supabase/server": "npm:@supabase/server@^1.1.0",
    "@supabase/supabase-js": "npm:@supabase/supabase-js@^2.106.1",
    "typebox": "npm:typebox@1.1.4",
    "typebox/schema": "npm:typebox@1.1.4/schema",
    "typebox/error": "npm:typebox@1.1.4/error",
    "typebox/value": "npm:typebox@1.1.4/value",
    "zod": "npm:zod@^4.4.3"
  }
}
